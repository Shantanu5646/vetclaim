# ── Twilio (https://www.twilio.com/console) ──────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Your phone number (the veteran's phone Twilio calls first) ────────
YOUR_PHONE_NUMBER=+1xxxxxxxxxx

# ── VA number (default: 1-800-827-1000) ──────────────────────────────
VA_NUMBER=+18008271000

# ── Public URL for Twilio webhooks (use ngrok for local dev) ─────────
# ngrok http 8000  →  copy the https:// URL here
PUBLIC_BASE_URL=https://your-ngrok-url.ngrok-free.app

# ── Anthropic API Key (document review + call summarization) ─────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── OpenAI API Key (Whisper transcription — optional) ────────────────
# If omitted, transcription is skipped and summary is not generated.
OPENAI_API_KEY=your_openai_key_here
